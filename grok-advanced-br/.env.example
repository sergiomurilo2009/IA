# ====================== .env.example ======================
# URL base do Ollama (servidor local)
OLLAMA_BASE_URL=http://localhost:11434

# Modelo de LLM para usar (deve estar instalado no Ollama)
LLM_MODEL=llama3.2

# Modelo de embedding para o banco vetorial
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Diretório para persistência do ChromaDB
CHROMA_PERSIST_DIR=./chroma_db

# Número máximo de iterações do CriticAgent
MAX_ITERATIONS=3

# Temperatura do modelo (0.0 a 1.0)
TEMPERATURE=0.7
